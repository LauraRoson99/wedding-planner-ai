# App
VITE_APP_NAME=Planifica2

# Base URL for static assets (leave empty to serve from the site root)
VITE_BASE_URL=

# Backend REST API base URL (must end in /api). Defaults to http://localhost:4000/api if unset.
VITE_API_URL=http://localhost:4000/api

# Routing: set to true to use hash-based routing (#/route) instead of the history API
VITE_USE_HASH_ROUTE=false
