generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  weddings Wedding[]
}

model Wedding {
  id        String    @id @default(cuid())
  name      String
  date      DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  guests Guest[]
  groups Group[]
  tables Table[]
  events Event[]

  @@index([ownerId])
}

enum RsvpStatus {
  PENDING
  CONFIRMED
  DECLINED
}

enum DietType {
  NONE
  VEGETARIAN
  VEGAN
  HALAL
  KOSHER
  OTHER
}

enum GuestRole {
  PRIMARY
  COMPANION
}

enum AgeGroup {
  ADULT
  CHILD
  BABY
}

model Guest {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  weddingId String
  wedding   Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  groupId String?
  group   Group?  @relation(fields: [groupId], references: [id], onDelete: SetNull)

  tableId String?
  table   Table?  @relation(fields: [tableId], references: [id], onDelete: SetNull)

  seatNumber Int?

  role      GuestRole  @default(PRIMARY)
  rsvp      RsvpStatus @default(PENDING)
  diet      DietType   @default(NONE)
  dietNotes String?
  allergies String[]   @default([])
  notes     String?
  ageGroup  AgeGroup   @default(ADULT)

  phone String?
  email String?

  parentId   String?
  parent     Guest?   @relation("GuestCompanions", fields: [parentId], references: [id], onDelete: Cascade)
  companions Guest[]  @relation("GuestCompanions")

  @@index([weddingId])
  @@index([groupId])
  @@index([tableId])
  @@index([parentId])
  @@index([seatNumber])
  @@unique([tableId, seatNumber])
}

model Group {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  weddingId String
  wedding   Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  guests Guest[]

  @@index([weddingId])
}

model Table {
  id        String   @id @default(cuid())
  name      String
  seats     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  weddingId String
  wedding   Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  guests Guest[]

  @@index([weddingId])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  date        DateTime
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  weddingId String
  wedding   Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@index([weddingId])
}
