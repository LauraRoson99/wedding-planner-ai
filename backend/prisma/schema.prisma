generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  weddings Wedding[]
}

model Wedding {
  id        String   @id @default(cuid())
  name      String
  date      DateTime?
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  guests    Guest[]
  groups    Group[]
  tables    Table[]
  events    Event[]
  tasks     Task[]

  budget       Budget?
  budgetItems  BudgetItem[]
  providers    Provider[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum TaskCategory {
  GUESTS
  CEREMONY
  BANQUET
  DECORATION
  PHOTO_VIDEO
  MUSIC
  TRAVEL
  OUTFITS
  PAPERWORK
  BUDGET
  OTHER
}

model Task {
  id        String       @id @default(cuid())
  title     String
  notes     String?
  completed Boolean      @default(false)

  dueDate   DateTime?
  priority  TaskPriority @default(MEDIUM)
  status    TaskStatus   @default(PENDING)
  category  TaskCategory @default(OTHER)

  weddingId String
  wedding   Wedding      @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([weddingId])
}

enum RsvpStatus {
  PENDING
  CONFIRMED
  DECLINED
}

enum DietType {
  NONE
  VEGETARIAN
  VEGAN
  HALAL
  KOSHER
  OTHER
}

enum GuestRole {
  PRIMARY
  COMPANION
}

enum AgeGroup {
  ADULT
  CHILD
  BABY
}

model Guest {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  weddingId String
  wedding   Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  groupId String?
  group   Group?  @relation(fields: [groupId], references: [id], onDelete: SetNull)

  tableId String?
  table   Table?  @relation(fields: [tableId], references: [id], onDelete: SetNull)

  seatNumber Int?

  role      GuestRole  @default(PRIMARY)
  rsvp      RsvpStatus @default(PENDING)
  diet      DietType   @default(NONE)
  dietNotes String?
  allergies String[]   @default([])
  notes     String?
  ageGroup  AgeGroup   @default(ADULT)

  phone String?
  email String?

  invitationSent   Boolean   @default(false)
  invitationSentAt DateTime?

  parentId   String?
  parent     Guest?   @relation("GuestCompanions", fields: [parentId], references: [id], onDelete: Cascade)
  companions Guest[]  @relation("GuestCompanions")

  @@index([weddingId])
  @@index([groupId])
  @@index([tableId])
  @@index([parentId])
  @@index([seatNumber])
  @@unique([tableId, seatNumber])
}

model Group {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  weddingId String
  wedding   Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  guests Guest[]

  @@index([weddingId])
}

model Table {
  id        String   @id @default(cuid())
  name      String
  seats     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  weddingId String
  wedding   Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  guests Guest[]

  @@index([weddingId])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  date        DateTime
  time        String?
  location    String?
  description String?

  weddingId   String
  wedding     Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([weddingId])
}

enum ProviderCategory {
  VENUE
  CATERING
  PHOTOGRAPHY
  VIDEO
  MUSIC
  FLORIST
  DECORATION
  TRANSPORT
  BEAUTY
  DRESS
  SUIT
  INVITATIONS
  HONEYMOON
  CEREMONY
  OTHER
}

enum ProviderStatus {
  CONTACTED
  QUOTED
  BOOKED
  CONFIRMED
  PAID
  CANCELLED
}

model Provider {
  id           String           @id @default(cuid())
  name         String
  category     ProviderCategory @default(OTHER)
  status       ProviderStatus   @default(CONTACTED)
  contactName  String?
  phone        String?
  email        String?
  website      String?
  estimatedPrice Float?
  finalPrice   Float?
  notes        String?

  weddingId    String
  wedding      Wedding          @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([weddingId])
}

enum BudgetCategory {
  VENUE
  CATERING
  DRESS
  SUIT
  PHOTO_VIDEO
  MUSIC
  DECORATION
  FLOWERS
  TRANSPORT
  INVITATIONS
  HONEYMOON
  BEAUTY
  CEREMONY
  GIFTS
  OTHER
}

enum BudgetItemStatus {
  PLANNED
  CONFIRMED
  PAID
  CANCELLED
}

model Budget {
  id          String   @id @default(cuid())
  weddingId   String   @unique
  wedding     Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  totalAmount Float    @default(0)
  currency    String   @default("EUR")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([weddingId])
}

model BudgetItem {
  id              String           @id @default(cuid())
  name            String
  category        BudgetCategory   @default(OTHER)

  estimatedAmount Float
  actualAmount    Float?
  paidAmount      Float            @default(0)

  status          BudgetItemStatus @default(PLANNED)
  dueDate         DateTime?
  paymentDate     DateTime?

  supplier        String?
  notes           String?

  weddingId       String
  wedding         Wedding          @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([weddingId])
  @@index([category])
  @@index([status])
}